<Page
    x:Class="PussyCatsApp.Views.PreferencesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="24" Padding="40" MaxWidth="600" HorizontalAlignment="Left">

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="Job Preferences" FontSize="32" FontWeight="SemiBold"/>
                    <TextBlock Text="Set up your filters so we can match you with the perfect jobs." Foreground="Gray"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Back" Click="BtnBack_Click" VerticalAlignment="Top" Margin="0,6,100,0"/>
            </Grid>

            <StackPanel Spacing="8">
                <TextBlock Text="Preferred Job Roles (Max 3)" FontWeight="Medium"/>
                <ListView x:Name="RolesListView"
                          SelectionMode="Multiple"
                          SelectionChanged="RolesListView_SelectionChanged"
                          Height="280"
                          CornerRadius="8"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                </ListView>
                <TextBlock x:Name="RoleWarningText" 
                           Foreground="Red" 
                           Visibility="Collapsed" 
                           Text="You can only select a maximum of 3 roles."/>
            </StackPanel>

            <ComboBox x:Name="WorkModeComboBox" 
                      Header="Preferred Work Mode" 
                      Width="300" 
                      PlaceholderText="Select work mode">
                <ComboBoxItem Content="Remote" Tag="Remote"/>
                <ComboBoxItem Content="Hybrid" Tag="Hybrid"/>
                <ComboBoxItem Content="On-site" Tag="OnSite"/>
            </ComboBox>

            <AutoSuggestBox x:Name="LocationAutoSuggestBox"
                            Header="Location (City, Country)"
                            PlaceholderText="e.g., Bucharest, Romania"
                            HorizontalAlignment="Stretch"
                            TextChanged="LocationAutoSuggestBox_TextChanged"
                            SuggestionChosen="LocationAutoSuggestBox_SuggestionChosen"/>

            <Button Content="Save Preferences" 
                    Style="{StaticResource AccentButtonStyle}" 
                    Click="SaveButton_Click" 
                    Width="150" 
                    Margin="0,16,0,0"/>

            <TextBlock x:Name="SuccessMessage" 
                       Foreground="Green" 
                       FontWeight="SemiBold" 
                       Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</Page>