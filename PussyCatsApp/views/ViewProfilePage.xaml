<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="PussyCatsApp.views.ViewProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <ScrollViewer>
        <StackPanel Margin="40" Spacing="20">
            <TextBlock Text="User Profile" Style="{StaticResource HeaderTextBlockStyle}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <PersonPicture x:Name="ProfilePersonPicture" Width="120" Height="120" HorizontalAlignment="Center"/>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="Personal Information" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                    <Grid ColumnSpacing="30" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="First Name" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="FirstNameText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Last Name" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="LastNameText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="Age" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="AgeText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="Gender" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="GenderText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Email" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="EmailText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1">
                            <TextBlock Text="Phone" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="PhoneText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="Country" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="CountryText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1">
                            <TextBlock Text="City" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="CityText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="University" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="UniversityText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="1">
                            <TextBlock Text="Graduation Year" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="GraduationYearText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
                            <TextBlock Text="Address" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="AddressText" FontSize="16" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="Links" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                    <Grid ColumnSpacing="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GitHub" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="GitHubText" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="LinkedIn" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <TextBlock x:Name="LinkedInText" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="Skills" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                    <ItemsRepeater x:Name="SkillsRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="5"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="12" Padding="10,5">
                                    <TextBlock Text="{Binding}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <TextBlock x:Name="NoSkillsText" Text="No skills added yet." Visibility="Collapsed" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="Motivation" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                    <TextBlock x:Name="MotivationText" TextWrapping="Wrap" FontSize="14"/>
                </StackPanel>
            </Border>
            <Button Content="Edit Profile" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Margin="0,10,0,30" Click="EditProfileButton_Click"/>
        </StackPanel>
    </ScrollViewer>
</Page>