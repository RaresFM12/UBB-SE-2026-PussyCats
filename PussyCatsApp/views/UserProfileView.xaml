<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCatsApp.views.UserProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PussyCatsApp.views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel>
            <!-- R40 — Profile Completeness Meter (separate component) -->
            <local:ProfileCompletenessBar x:Name="completenessBar" />

            <Grid Padding="20,40,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="15" Margin="40,0,40,0" VerticalAlignment="Center">
                    <PersonPicture x:Name="pbAvatar" Width="200" Height="200" HorizontalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <Button x:Name="btnUploadAvatar" Content="Upload avatar" Click="OnAvatarUploadClick" Width="140" />
                        <Button x:Name="btnRemoveAvatar" Content="Remove avatar" Click="OnAvatarRemoveClick" Width="140" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="30"
                            VerticalAlignment="Center">

                    <Border Background="#9b72a8"
                            CornerRadius="12"
                            Padding="20"
                            MinWidth="220"
                            HorizontalAlignment="Left">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="12">
                            <TextBlock Text="Account Status"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <ToggleSwitch x:Name="chkAccountStatus"
                                          Toggled="OnStatusToggle"
                                          OnContent="Active"
                                          OffContent="Inactive"
                                          Foreground="White"
                                          HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="6"
                                VerticalAlignment="Center"
                                MaxWidth="320">
                        <TextBlock x:Name="LevelTitleText"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Medium" />
                        <ProgressBar x:Name="XpProgressBar"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="12"
                                     Foreground="#9b72a8"
                                     Background="Black" />
                        <TextBlock x:Name="XpCountText"
                                   Foreground="#D4B8E0"
                                   FontSize="12" />
                    </StackPanel>

                </StackPanel>

                <TextBlock x:Name="lblFreshness" Grid.Column="1" Text="Profile last updated:..." HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0.7" FontSize="13" />
            </Grid>

            <Grid Padding="30,60,30,80" MinHeight="600">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            Spacing="25"
                            HorizontalAlignment="Left"
                            Margin="20,0,0,0">
                    <TextBlock x:Name="lblFirstName" Text="First Name: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblLastName" Text="Last Name: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblEmail" Text="Email: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblPhone" Text="Phone: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblGithubAccount" Text="GitHub: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblLinkedinAccount" Text="LinkedIn: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblGender" Text="Gender: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblUniversity" Text="University: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblCountry" Text="Country: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblAddress" Text="Address: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblGraduationYear" Text="Graduation Year: " Foreground="Black" FontSize="16" />
                    <TextBlock x:Name="lblError" Foreground="#FFA0A0" TextWrapping="Wrap" Margin="0,20,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="25" HorizontalAlignment="Right" Width="300" Margin="0,0,75,0">
                    <Button x:Name="btnEdit" Content="Edit Profile" HorizontalAlignment="Stretch" />
                    <Button x:Name="btnPersonalityTest" Content="Take Personality Test" HorizontalAlignment="Stretch" Click="OnPersonalityTestClick"/>
                    <Button x:Name="btnExportPdf" Content="Export to PDF" HorizontalAlignment="Stretch" />
                    <Button x:Name="btnViewDocuments" Content="View Documents" HorizontalAlignment="Stretch" />
                    <Button x:Name="btnMatchHistory" Content="Match History" HorizontalAlignment="Stretch" />
                    <Button x:Name="btnRoleCompatibility" Content="Role Compatibility Analyzer" Click="OnCompatibilityAnalyzerClick" HorizontalAlignment="Stretch" />
                    <Button x:Name="btnPublicProfile" Content="See Public Profile" HorizontalAlignment="Stretch" />
                    <Button x:Name="btnOldTests" Content="Go to old tests" HorizontalAlignment="Stretch" />
                    <Button x:Name="btnSkillTests" Content="Skill Tests" HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>