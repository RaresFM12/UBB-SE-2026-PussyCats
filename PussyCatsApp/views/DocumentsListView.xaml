<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCatsApp.Views.DocumentsListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="30,30,30,40" Spacing="30">

            <!-- ── Back button ─────────────────────────────────────────── -->
            <Button x:Name="btnBack"
                    Content="← Back"
                    Click="OnBackClick"
                    HorizontalAlignment="Left" />

            <!-- ── UPLOAD SECTION ─────────────────────────────────────── -->
            <Border Background="#9b72a8"
                    CornerRadius="12"
                    Padding="24">
                <StackPanel Spacing="16">

                    <TextBlock Text="Upload Document"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold" />

                    <!-- Document name input -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Document Name"
                                   Foreground="White"
                                   FontSize="14" />
                        <TextBox x:Name="txtDocumentName"
                                 PlaceholderText="e.g. AWS Certificate 2024"
                                 TextChanged="OnDocumentNameChanged"
                                 MaxWidth="400"
                                 HorizontalAlignment="Left" />
                    </StackPanel>

                    <!-- File picker row -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="btnBrowse"
                                Content="Browse File…"
                                Click="OnBrowseClick" />
                        <TextBlock x:Name="lblSelectedFile"
                                   Text="No file selected"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Opacity="0.85" />
                    </StackPanel>

                    <TextBlock Text="Accepted formats: PDF, JPG, PNG"
                               Foreground="White"
                               FontSize="12"
                               Opacity="0.7" />

                    <!-- Error label -->
                    <TextBlock x:Name="lblUploadError"
                               Foreground="#FFD0D0"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />

                    <!-- Upload button -->
                    <Button x:Name="btnUpload"
                            Content="Upload"
                            Click="OnUploadClick"
                            HorizontalAlignment="Left" />

                </StackPanel>
            </Border>

            <!-- ── DOCUMENT LIST SECTION ───────────────────────────────── -->
            <StackPanel Spacing="12">

                <TextBlock Text="Uploaded Documents"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="Black" />

                <!-- Empty state -->
                <TextBlock x:Name="lblNoDocuments"
                           Text="No documents uploaded yet."
                           Foreground="Gray"
                           FontSize="14"
                           Visibility="Collapsed" />

                <!-- Status message (e.g. file not found on disk) -->
                <TextBlock x:Name="lblStatus"
                           Foreground="#c0392b"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <!-- Document list -->
                <ListView x:Name="lvDocuments"
                          SelectionMode="Single"
                          IsItemClickEnabled="False">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#f5f0fa"
                                    CornerRadius="8"
                                    Padding="16,12"
                                    Margin="0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Name + date -->
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DocumentName}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2c1a3e" />
                                        <TextBlock Text="{Binding UploadDate}"
                                                   FontSize="12"
                                                   Foreground="Gray" />
                                    </StackPanel>

                                    <!-- View button -->
                                    <Button Grid.Column="1"
                                            Content="View"
                                            Margin="0,0,10,0"
                                            Tag="{Binding}"
                                            Click="OnViewClick" />

                                    <!-- Delete button -->
                                    <Button Grid.Column="2"
                                            Content="Delete"
                                            Tag="{Binding}"
                                            Click="OnDeleteClick" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
