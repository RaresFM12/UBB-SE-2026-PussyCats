<Page
    x:Class="PussyCatsApp.views.ExportCVTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,20">
            <Button Content="Back to Profile" Click="OnBackClick" />

            <Button Content="Generate &amp; Download PDF"
                    Command="{Binding ExportCVCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource BoolNegationConverter}}"/>

            <ProgressRing IsActive="{Binding IsLoading}" Width="24" Height="24" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="Red" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <WebView2 x:Name="CvWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Border>
    </Grid>

</Page>