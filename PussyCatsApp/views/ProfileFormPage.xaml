<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="PussyCatsApp.views.ProfileFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:PussyCatsApp.views"
      xmlns:converters="using:PussyCatsApp.converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
    </Page.Resources>

    <ScrollViewer>
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="User Profile Form" Style="{StaticResource HeaderTextBlockStyle}"
                       Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <!-- CV Upload Section -->
            <StackPanel Grid.Row="1" Margin="0,0,0,30">
                <TextBlock Text="Upload CV for Auto-Population" Style="{StaticResource SubtitleTextBlockStyle}"
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="UploadCVButton" Click="UploadCVButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE898;"/>
                            <TextBlock Text="Upload CV (.json or .xml)"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="CVStatusText" VerticalAlignment="Center" Foreground="Green"/>
                </StackPanel>
                <InfoBar x:Name="CVUploadInfoBar" Severity="Informational" IsOpen="False" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Form Fields -->
            <StackPanel Grid.Row="2" Spacing="15">
                <!-- Required Fields Section -->
                <TextBlock Text="Required Information" Style="{StaticResource SubtitleTextBlockStyle}"
                           FontWeight="SemiBold" Margin="0,10,0,5"/>

                <Grid ColumnSpacing="20" RowSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- First Name and Last Name -->
                    <TextBox Grid.Row="0" Grid.Column="0" x:Name="FirstNameTextBox"
                             Header="First Name *" PlaceholderText="Enter first name"
                             MaxLength="50"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="LastNameTextBox"
                             Header="Last Name *" PlaceholderText="Enter last name"
                             MaxLength="60"/>

                    <!-- Age and Gender -->
                    <NumberBox Grid.Row="1" Grid.Column="0" x:Name="AgeNumberBox"
                               Header="Age *" PlaceholderText="Age"
                               Minimum="16" Maximum="60" SpinButtonPlacementMode="Inline"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="GenderComboBox"
                              Header="Gender *" PlaceholderText="Select gender"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem>Male</ComboBoxItem>
                        <ComboBoxItem>Female</ComboBoxItem>
                    </ComboBox>

                    <!-- Email and Phone -->
                    <TextBox Grid.Row="2" Grid.Column="0" x:Name="EmailTextBox"
                             Header="Email Address *" PlaceholderText="email@example.com"
                             MaxLength="254"/>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBlock Text="Phone Number *" Margin="0,0,0,5"/>
                        <Grid ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" x:Name="PhonePrefixComboBox"
                                      PlaceholderText="Prefix" Width="100">
                                <ComboBoxItem>+40</ComboBoxItem>
                                <ComboBoxItem>+44</ComboBoxItem>
                                <ComboBoxItem>+49</ComboBoxItem>
                                <ComboBoxItem>+33</ComboBoxItem>
                                <ComboBoxItem>+39</ComboBoxItem>
                                <ComboBoxItem>+34</ComboBoxItem>
                                <ComboBoxItem>+31</ComboBoxItem>
                                <ComboBoxItem>+48</ComboBoxItem>
                                <ComboBoxItem>+43</ComboBoxItem>
                                <ComboBoxItem>+32</ComboBoxItem>
                            </ComboBox>
                            <TextBox Grid.Column="1" x:Name="PhoneNumberTextBox"
                                     PlaceholderText="Phone number" MaxLength="12"/>
                        </Grid>
                    </StackPanel>

                    <!-- GitHub and LinkedIn -->
                    <TextBox Grid.Row="3" Grid.Column="0" x:Name="GitHubTextBox"
                             Header="GitHub Account" PlaceholderText="github.com/username"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="LinkedInTextBox"
                             Header="LinkedIn Account" PlaceholderText="linkedin.com/in/username"/>

                    <!-- Country and City -->
                    <ComboBox Grid.Row="4" Grid.Column="0" x:Name="CountryComboBox"
                              Header="Country *" PlaceholderText="Select country"
                              IsEditable="True" HorizontalAlignment="Stretch"
                              SelectionChanged="CountryComboBox_SelectionChanged">
                        <ComboBoxItem>Romania</ComboBoxItem>
                        <ComboBoxItem>Germany</ComboBoxItem>
                        <ComboBoxItem>France</ComboBoxItem>
                        <ComboBoxItem>Italy</ComboBoxItem>
                        <ComboBoxItem>Spain</ComboBoxItem>
                        <ComboBoxItem>United Kingdom</ComboBoxItem>
                        <ComboBoxItem>Netherlands</ComboBoxItem>
                        <ComboBoxItem>Belgium</ComboBoxItem>
                        <ComboBoxItem>Poland</ComboBoxItem>
                        <ComboBoxItem>Austria</ComboBoxItem>
                        <ComboBoxItem>Sweden</ComboBoxItem>
                        <ComboBoxItem>Portugal</ComboBoxItem>
                        <ComboBoxItem>Czech Republic</ComboBoxItem>
                        <ComboBoxItem>Hungary</ComboBoxItem>
                        <ComboBoxItem>Bulgaria</ComboBoxItem>
                        <ComboBoxItem>Greece</ComboBoxItem>
                        <ComboBoxItem>Denmark</ComboBoxItem>
                        <ComboBoxItem>Finland</ComboBoxItem>
                        <ComboBoxItem>Ireland</ComboBoxItem>
                        <ComboBoxItem>Croatia</ComboBoxItem>
                        <ComboBoxItem>Slovakia</ComboBoxItem>
                        <ComboBoxItem>Lithuania</ComboBoxItem>
                        <ComboBoxItem>Latvia</ComboBoxItem>
                        <ComboBoxItem>Estonia</ComboBoxItem>
                        <ComboBoxItem>Slovenia</ComboBoxItem>
                        <ComboBoxItem>Luxembourg</ComboBoxItem>
                        <ComboBoxItem>Malta</ComboBoxItem>
                        <ComboBoxItem>Cyprus</ComboBoxItem>
                        <ComboBoxItem>United States</ComboBoxItem>
                        <ComboBoxItem>Canada</ComboBoxItem>
                        <ComboBoxItem>Australia</ComboBoxItem>
                        <ComboBoxItem>Other</ComboBoxItem>
                    </ComboBox>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="CityTextBox"
                             Header="City *" PlaceholderText="Enter city"
                             MaxLength="100"/>

                    <!-- University and Expected Graduation Year -->
                    <AutoSuggestBox Grid.Row="5" Grid.Column="0" x:Name="UniversityAutoSuggest"
                                    Header="University *" PlaceholderText="Enter university name"
                                    TextChanged="UniversityAutoSuggest_TextChanged"
                                    QuerySubmitted="UniversityAutoSuggest_QuerySubmitted"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" x:Name="GraduationYearComboBox"
                              Header="Expected Graduation Year *"
                              PlaceholderText="Select year" HorizontalAlignment="Stretch"/>

                    <!-- Address -->
                    <TextBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                             x:Name="AddressTextBox" Header="Address"
                             PlaceholderText="Enter full address"/>
                </Grid>

                <!-- Optional Fields Section -->
                <TextBlock Text="Optional Information" Style="{StaticResource SubtitleTextBlockStyle}"
                           FontWeight="SemiBold" Margin="0,20,0,5"/>

                <!-- Skills -->
                <StackPanel>
                    <TextBlock Text="Skills (max 30)" Margin="0,0,0,5"/>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox Grid.Column="0" x:Name="SkillsAutoSuggest"
                                        PlaceholderText="Type a skill and press Enter"
                                        QuerySubmitted="SkillsAutoSuggest_QuerySubmitted"
                                        TextChanged="SkillsAutoSuggest_TextChanged"/>
                        <Button Grid.Column="1" x:Name="AddSkillButton" Content="Add Skill"
                                Click="AddSkillButton_Click"/>
                    </Grid>
                    <ItemsRepeater x:Name="SkillsItemsRepeater" Margin="0,10,0,0">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="5"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource DefaultButtonStyle}"
                                        Tag="{Binding}" Click="RemoveSkillButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="{Binding}"/>
                                        <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Work Experience -->
                <Expander Header="Work Experience" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left">
                    <StackPanel Spacing="10" Margin="0,10,0,0">
                        <Button x:Name="AddWorkExperienceButton" Content="Add Work Experience"
                                Click="AddWorkExperienceButton_Click"/>
                        <ItemsRepeater x:Name="WorkExperienceItemsRepeater">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1"
                                            CornerRadius="5" Padding="10" Margin="0,5">
                                        <Grid RowSpacing="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Header="Company"
                                                         Text="{Binding Company}" MaxLength="150"/>
                                                <TextBox Grid.Column="1" Header="Job Title"
                                                         Text="{Binding JobTitle}" MaxLength="100"/>
                                                <Button Grid.Column="2" Content="Remove"
                                                        VerticalAlignment="Bottom"
                                                        Tag="{Binding}"
                                                        Click="RemoveWorkExperienceButton_Click"/>
                                            </Grid>

                                            <Grid Grid.Row="1" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <DatePicker Grid.Column="0" Header="Start Date"
                                                            Date="{Binding StartDate}"/>
                                                <DatePicker Grid.Column="1" Header="End Date"
                                                            Date="{Binding EndDate}"
                                                            IsEnabled="{Binding CurrentlyWorking, Converter={StaticResource BoolNegationConverter}}"/>
                                            </Grid>

                                            <CheckBox Grid.Row="2" Content="Currently Working Here"
                                                      IsChecked="{Binding CurrentlyWorking}"/>

                                            <TextBox Grid.Row="3" Header="Description"
                                                     Text="{Binding Description}"
                                                     TextWrapping="Wrap" MaxLength="500"
                                                     AcceptsReturn="True" Height="80"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Expander>

                <!-- Projects -->
                <Expander Header="Projects" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left">
                    <StackPanel Spacing="10" Margin="0,10,0,0">
                        <Button x:Name="AddProjectButton" Content="Add Project"
                                Click="AddProjectButton_Click"/>
                        <ItemsRepeater x:Name="ProjectsItemsRepeater">
                            <!-- Project template will be similar to work experience -->
                        </ItemsRepeater>
                    </StackPanel>
                </Expander>

                <!-- Motivation -->
                <TextBox x:Name="MotivationTextBox" Header="Motivation"
                         PlaceholderText="Describe your motivation..."
                         TextWrapping="Wrap" MaxLength="1000"
                         AcceptsReturn="True" Height="120"/>

                <!-- Buttons -->
                <Grid Margin="0,30,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" x:Name="CancelButton" Content="Cancel"
                            Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button Grid.Column="2" x:Name="SaveButton" Content="Save Profile"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="SaveButton_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>